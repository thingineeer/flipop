default_platform(:ios)

platform :ios do

  # ── 공통: Flutter 빌드 ──
  private_lane :flutter_build_ios do
    Dir.chdir("../..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
      sh("flutter", "build", "ios", "--release", "--no-codesign")
    end
  end

  # ──────────────────────────────────────────
  # beta: Flutter build → TestFlight 업로드
  # ──────────────────────────────────────────
  desc "Flutter build iOS & upload to TestFlight"
  lane :beta do
    flutter_build_ios

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "flipop.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "8Q4H7X3Q58",
        uploadBitcode: false,
        uploadSymbols: true,
      }
    )

    pilot(
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  # ──────────────────────────────────────────
  # release: Flutter build → App Store 배포
  # ──────────────────────────────────────────
  desc "Flutter build iOS & submit to App Store"
  lane :release do
    flutter_build_ios

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "flipop.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "8Q4H7X3Q58",
        uploadBitcode: false,
        uploadSymbols: true,
      }
    )

    deliver(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      metadata_path: "./fastlane/metadata",
    )
  end

  # ──────────────────────────────────────────
  # metadata: 메타데이터만 업로드
  # ──────────────────────────────────────────
  desc "Upload metadata only (no binary)"
  lane :metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      metadata_path: "./fastlane/metadata",
    )
  end

  # ──────────────────────────────────────────
  # screenshots: 스크린샷만 업로드
  # ──────────────────────────────────────────
  desc "Upload screenshots only"
  lane :screenshots do
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
    )
  end
end
