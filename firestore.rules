rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 닉네임 정규표현식 검증 함수
    function isValidNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 12
        && nickname.matches('^[가-힣a-zA-Z0-9]{2,12}$');
    }

    // 유저 프로필: 본인 문서 읽기/쓰기 + 닉네임 검증
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      // 닉네임 중복 체크 쿼리 허용 (인증 + limit 1)
      allow list: if request.auth != null
                  && request.query.limit <= 1;
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && isValidNickname(request.resource.data.nickname);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 순위표: 인증된 사용자 읽기만 허용
    // 쓰기는 Cloud Function (submitScore)을 통해서만 가능
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // 클라이언트 직접 쓰기 차단 — Cloud Function 전용
    }
  }
}
