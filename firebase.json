{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "flipop-game",
          "appId": "1:576288394502:android:0b4933ed836c18ddd8a287",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "flipop-game",
          "appId": "1:576288394502:ios:f935ff9bb7376a38d8a287",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "flipop-game",
          "configurations": {
            "android": "1:576288394502:android:0b4933ed836c18ddd8a287",
            "ios": "1:576288394502:ios:f935ff9bb7376a38d8a287"
          }
        }
      }
    }
  }
}